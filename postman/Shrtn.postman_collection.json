    {
      "name": "Redirect Short Link",
      "item": [
        {
          "name": "Redirect Created Short Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 302', function () {\r",
                  "  pm.response.to.have.status(302)\r",
                  "})\r",
                  "\r",
                  "pm.test('Location header contains the original URL', function () {\r",
                  "  pm.expect(pm.response.headers.get('Location')).to.eql(\r",
                  "    'https://example.com/products?id=123',\r",
                  "  )\r",
                  "})\r",
                  "\r",
                  "pm.test('Short URL variable was created', function () {\r",
                  "  const shortUrl = pm.collectionVariables.get('shortUrl')\r",
                  "\r",
                  "  pm.expect(shortUrl).to.be.a('string')\r",
                  "  pm.expect(shortUrl).to.match(\r",
                  "    /^http:\\/\\/localhost:5056\\/[A-Za-z0-9]{7}$/,\r",
                  "  )\r",
                  "})\r",
                  "\r",
                  "pm.test('Response does not expose API error JSON', function () {\r",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.not.include(\r",
                  "    'application/json',\r",
                  "  )\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{shortUrl}}",
              "host": [
                "{{shortUrl}}"
              ]
            }
          },
          "response": []
