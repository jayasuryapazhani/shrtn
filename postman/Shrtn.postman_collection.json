{
  "info": {
    "_postman_id": "2faed6f5-b15c-49f8-9771-eac99229f001",
    "name": "Shrtn API",
    "description": "Postman collection for validating the Shrtn URL-shortening API. The current release uses temporary in-memory storage and does not yet implement redirect handling.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5056",
      "type": "string"
    },
    {
      "key": "shortCode",
      "value": "",
      "type": "string"
    },
    {
      "key": "shortUrl",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Confirms that the Shrtn API is running."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200)",
                  "})",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json')",
                  "})",
                  "",
                  "pm.test('Health metadata is correct', function () {",
                  "  pm.expect(responseBody).to.include({",
                  "    status: 'UP',",
                  "    service: 'shrtn-api',",
                  "    version: '0.2.0'",
                  "  })",
                  "})",
                  "",
                  "pm.test('Timestamp is a valid ISO date', function () {",
                  "  pm.expect(Number.isNaN(Date.parse(responseBody.timestamp))).to.eql(false)",
                  "})"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Create Short Link",
      "item": [
        {
          "name": "Create Valid Short Link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"https://example.com/products?id=123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/links",
            "description": "Creates a short-link record for a valid HTTPS URL."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "const data = responseBody.data",
                  "const baseUrl = pm.collectionVariables.get('baseUrl')",
                  "",
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201)",
                  "})",
                  "",
                  "pm.test('Location header is present', function () {",
                  "  pm.expect(pm.response.headers.has('Location')).to.eql(true)",
                  "  pm.expect(pm.response.headers.get('Location')).to.eql(data.shortUrl)",
                  "})",
                  "",
                  "pm.test('Original URL is returned unchanged', function () {",
                  "  pm.expect(data.originalUrl).to.eql('https://example.com/products?id=123')",
                  "})",
                  "",
                  "pm.test('Short code contains seven alphanumeric characters', function () {",
                  "  pm.expect(data.shortCode).to.match(/^[A-Za-z0-9]{7}$/)",
                  "})",
                  "",
                  "pm.test('Short URL uses the configured base URL', function () {",
                  "  pm.expect(data.shortUrl).to.eql(`${baseUrl}/${data.shortCode}`)",
                  "})",
                  "",
                  "pm.test('Created timestamp is valid', function () {",
                  "  pm.expect(Number.isNaN(Date.parse(data.createdAt))).to.eql(false)",
                  "})",
                  "",
                  "if (pm.response.code === 201 && data) {",
                  "  pm.collectionVariables.set('shortCode', data.shortCode)",
                  "  pm.collectionVariables.set('shortUrl', data.shortUrl)",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Reject Missing Original URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/links",
            "description": "Verifies that originalUrl is required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400)",
                  "})",
                  "",
                  "pm.test('Error code is VALIDATION_ERROR', function () {",
                  "  pm.expect(responseBody.error.code).to.eql('VALIDATION_ERROR')",
                  "})",
                  "",
                  "pm.test('Error identifies originalUrl', function () {",
                  "  const hasOriginalUrlError = responseBody.error.details.some(function (detail) {",
                  "    return detail.field === 'originalUrl'",
                  "  })",
                  "",
                  "  pm.expect(hasOriginalUrlError).to.eql(true)",
                  "})"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Reject Invalid URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"not a URL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/links",
            "description": "Verifies malformed URL validation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400)",
                  "})",
                  "",
                  "pm.test('Error code is VALIDATION_ERROR', function () {",
                  "  pm.expect(responseBody.error.code).to.eql('VALIDATION_ERROR')",
                  "})",
                  "",
                  "pm.test('Error explains that the URL is invalid', function () {",
                  "  const hasExpectedMessage = responseBody.error.details.some(function (detail) {",
                  "    return detail.message === 'originalUrl must be a valid URL.'",
                  "  })",
                  "",
                  "  pm.expect(hasExpectedMessage).to.eql(true)",
                  "})"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Reject Unsupported Protocol",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"ftp://example.com/file.zip\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/links",
            "description": "Verifies that only HTTP and HTTPS protocols are accepted."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400)",
                  "})",
                  "",
                  "pm.test('Error code is VALIDATION_ERROR', function () {",
                  "  pm.expect(responseBody.error.code).to.eql('VALIDATION_ERROR')",
                  "})",
                  "",
                  "pm.test('Error explains supported protocols', function () {",
                  "  const hasExpectedMessage = responseBody.error.details.some(function (detail) {",
                  "    return detail.message === 'Only HTTP and HTTPS URLs are supported.'",
                  "  })",
                  "",
                  "  pm.expect(hasExpectedMessage).to.eql(true)",
                  "})"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Reject Unsupported Request Field",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"https://example.com\",\n  \"unsupportedField\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/links",
            "description": "Verifies that the request body rejects unknown properties."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400)",
                  "})",
                  "",
                  "pm.test('Error code is VALIDATION_ERROR', function () {",
                  "  pm.expect(responseBody.error.code).to.eql('VALIDATION_ERROR')",
                  "})"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Reject Malformed JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\":\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/links",
            "description": "Verifies the response returned when JSON parsing fails."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400)",
                  "})",
                  "",
                  "pm.test('Error code is INVALID_JSON', function () {",
                  "  pm.expect(responseBody.error.code).to.eql('INVALID_JSON')",
                  "})",
                  "",
                  "pm.test('Response uses a safe parsing message', function () {",
                  "  pm.expect(responseBody.error.message).to.eql('The request body contains invalid JSON.')",
                  "})"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    }
  ]
}