{
  "info": {
    "_postman_id": "684fdf57-05f8-49df-a02e-8b1bbc2678c1",
    "name": "Shrtn API",
    "description": "Postman collection for validating Shrtn API version 0.8.0. It covers health, the complete short-link lifecycle, validation failures, redirect behavior, analytics, PostgreSQL-backed persistence, and security headers. The default baseUrl targets the Railway production service. Change baseUrl to http://localhost:5056 for local testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get API Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200)",
                  "})",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json')",
                  "})",
                  "",
                  "pm.test('Health metadata is correct', function () {",
                  "  pm.expect(responseBody).to.include({",
                  "    status: 'UP',",
                  "    service: 'shrtn-api',",
                  "    version: '0.8.0'",
                  "  })",
                  "})",
                  "",
                  "pm.test('Timestamp is a valid ISO date', function () {",
                  "  pm.expect(Number.isNaN(Date.parse(responseBody.timestamp))).to.eql(false)",
                  "})",
                  "",
                  "pm.test('Security headers are present', function () {",
                  "  pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff')",
                  "  pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('SAMEORIGIN')",
                  "  pm.expect(pm.response.headers.get('Referrer-Policy')).to.eql('no-referrer')",
                  "})",
                  "",
                  "pm.test('Express technology disclosure is disabled', function () {",
                  "  pm.expect(pm.response.headers.has('X-Powered-By')).to.eql(false)",
                  "})"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Confirms that Shrtn API version 0.8.0 is running and returns defensive HTTP headers."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Short-Link Lifecycle",
      "item": [
        {
          "name": "1. Create Valid Short Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "const data = responseBody.data",
                  "const baseUrl = pm.collectionVariables.get('baseUrl').replace(/\\/$/, '')",
                  "const originalUrl = pm.collectionVariables.get('originalUrl')",
                  "",
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201)",
                  "})",
                  "",
                  "pm.test('Location header matches the short URL', function () {",
                  "  pm.expect(pm.response.headers.get('Location')).to.eql(data.shortUrl)",
                  "})",
                  "",
                  "pm.test('Original URL is returned unchanged', function () {",
                  "  pm.expect(data.originalUrl).to.eql(originalUrl)",
                  "})",
                  "",
                  "pm.test('Short code contains seven alphanumeric characters', function () {",
                  "  pm.expect(data.shortCode).to.match(/^[A-Za-z0-9]{7}$/)",
                  "})",
                  "",
                  "pm.test('Short URL uses the configured base URL', function () {",
                  "  pm.expect(data.shortUrl).to.eql(`${baseUrl}/${data.shortCode}`)",
                  "})",
                  "",
                  "pm.test('Created timestamp is valid', function () {",
                  "  pm.expect(Number.isNaN(Date.parse(data.createdAt))).to.eql(false)",
                  "})",
                  "",
                  "if (pm.response.code === 201 && data) {",
                  "  pm.collectionVariables.set('shortCode', data.shortCode)",
                  "  pm.collectionVariables.set('shortUrl', data.shortUrl)",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links"
              ]
            },
            "description": "Creates and persists a short link for the configured originalUrl.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"{{originalUrl}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "2. Get Initial Analytics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "const data = responseBody.data",
                  "const shortCode = pm.collectionVariables.get('shortCode')",
                  "const originalUrl = pm.collectionVariables.get('originalUrl')",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200)",
                  "})",
                  "",
                  "pm.test('Analytics match the created link', function () {",
                  "  pm.expect(data.shortCode).to.eql(shortCode)",
                  "  pm.expect(data.originalUrl).to.eql(originalUrl)",
                  "})",
                  "",
                  "pm.test('A new link has zero recorded clicks', function () {",
                  "  pm.expect(data.clickCount).to.eql(0)",
                  "  pm.expect(data.lastClickedAt).to.eql(null)",
                  "})",
                  "",
                  "pm.test('Created timestamp is valid', function () {",
                  "  pm.expect(Number.isNaN(Date.parse(data.createdAt))).to.eql(false)",
                  "})",
                  "",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('initialClickCount', String(data.clickCount))",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{shortCode}}/analytics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links",
                "{{shortCode}}",
                "analytics"
              ]
            },
            "description": "Confirms that a newly created link starts with zero clicks."
          },
          "response": []
        },
        {
          "name": "3. Redirect Created Short Link",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const originalUrl = pm.collectionVariables.get('originalUrl')",
                  "const shortUrl = pm.collectionVariables.get('shortUrl')",
                  "",
                  "pm.test('Status code is 302', function () {",
                  "  pm.response.to.have.status(302)",
                  "})",
                  "",
                  "pm.test('Location header contains the original URL', function () {",
                  "  pm.expect(pm.response.headers.get('Location')).to.eql(originalUrl)",
                  "})",
                  "",
                  "pm.test('Short URL variable is valid', function () {",
                  "  pm.expect(shortUrl).to.be.a('string')",
                  "  pm.expect(shortUrl).to.match(/^https?:\\/\\/.+\\/[A-Za-z0-9]{7}$/)",
                  "})",
                  "",
                  "pm.test('Redirect does not expose an API JSON error', function () {",
                  "  const contentType = pm.response.headers.get('Content-Type')",
                  "  pm.expect(contentType || '').to.not.include('application/json')",
                  "})"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{shortUrl}}",
              "host": [
                "{{shortUrl}}"
              ]
            },
            "description": "Redirects the created short URL without automatically following the destination."
          },
          "response": [],
          "protocolProfileBehavior": {
            "followRedirects": false
          }
        },
        {
          "name": "4. Get Updated Analytics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const responseBody = pm.response.json()",
                  "const data = responseBody.data",
                  "const shortCode = pm.collectionVariables.get('shortCode')",
                  "const initialClickCount = Number(pm.collectionVariables.get('initialClickCount'))",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200)",
                  "})",
                  "",
                  "pm.test('Analytics belong to the created link', function () {",
                  "  pm.expect(data.shortCode).to.eql(shortCode)",
                  "})",
                  "",
                  "pm.test('Redirect increments the click count', function () {",
                  "  pm.expect(data.clickCount).to.be.above(initialClickCount)",
                  "})",
                  "",
                  "pm.test('Last-click timestamp is valid', function () {",
                  "  pm.expect(data.lastClickedAt).to.be.a('string')",
                  "  pm.expect(Number.isNaN(Date.parse(data.lastClickedAt))).to.eql(false)",
                  "})"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/links/{{shortCode}}/analytics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "links",
                "{{shortCode}}",
                "analytics"
              ]
            },
            "description": "Confirms that the redirect incremented the click count and updated lastClickedAt."
          },
          "response": []
        }
      ]
    },
