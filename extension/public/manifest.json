
{
  "manifest_version": 3,
  "name": "Shrtn",
  "description": "Shorten links and generate shareable QR codes from your browser.",
  "version": "0.4.0",
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Open Shrtn",
    "default_popup": "index.html"
  }
}